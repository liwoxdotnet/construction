---
import Layout from "@/layouts/Layout.astro";
import AnnouncementBar from "@/components/AnnouncementBar.astro";
import Nav from "@/components/Nav.astro";
---

<Layout title="Construction Design Workflow">
  <AnnouncementBar />
  <Nav />

<main class="px-6 py-16 max-w-6xl mx-auto">

  <section class="text-center mb-20">
    <h1 class="text-4xl md:text-5xl font-bold mb-6">
      A smarter way to manage construction design work
    </h1>

    <p class="text-lg text-muted-foreground max-w-2xl mx-auto mb-8">
      Upload drawings, track revisions, and manage queries in one structured system—without email confusion or version chaos.
    </p>

    <div class="flex justify-center gap-4">
      <a href="/dashboard" class="bg-black text-white px-6 py-3 rounded-lg">
        Go to Dashboard
      </a>

      <a href="/login" class="border px-6 py-3 rounded-lg">
        Login
      </a>
    </div>
  </section>

<section class="mb-20">
  <h2 class="text-2xl md:text-3xl font-bold text-center mb-10">
    Design work shouldn’t be this messy
  </h2>

  <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">

    <div class="border p-6 rounded-lg">
      <p>Drawings are shared across emails and WhatsApp with no clear structure.</p>
    </div>

    <div class="border p-6 rounded-lg">
      <p>Multiple versions create confusion — no one knows the latest file.</p>
    </div>

    <div class="border p-6 rounded-lg">
      <p>Important changes are not properly tracked or documented.</p>
    </div>

    <div class="border p-6 rounded-lg">
      <p>Communication between teams becomes fragmented and unclear.</p>
    </div>

  </div>
</section>

</main>

</Layout>
