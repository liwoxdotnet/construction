---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Dashboard">

  <div class="flex min-h-screen">

    <!-- SIDEBAR -->
    <aside class="w-64 border-r p-6 hidden md:block">
      <h2 class="text-xl font-bold mb-6">Dashboard</h2>

      <nav class="flex flex-col gap-4 text-sm">
        <a href="#" class="text-black font-medium">My Work</a>
        <a href="#" class="text-gray-600">Upload</a>
        <a href="#" class="text-gray-600">Queries</a>
        <a href="#" class="text-gray-600">Versions</a>
      </nav>
    </aside>

    <!-- MAIN -->
    <main class="flex-1 p-8">

      <h1 class="text-2xl font-bold mb-6">My Work</h1>

      <!-- Upload -->
      <div class="border p-6 rounded-lg mb-8">
        <h2 class="font-semibold mb-4">Upload Design</h2>

        <input type="file" id="fileInput" class="mb-4" />

        <textarea
          id="description"
          placeholder="Describe update..."
          class="w-full border p-2 mb-4 rounded"
        ></textarea>

        <button
          onclick="uploadFile()"
          class="bg-black text-white px-4 py-2 rounded"
        >
          Upload
        </button>

        <p id="uploadStatus" class="text-sm text-gray-600 mt-3"></p>
      </div>

      <!-- Updates -->
      <div class="border p-6 rounded-lg mb-8">
        <h2 class="font-semibold mb-4">Recent Updates</h2>

        <div id="updatesList" class="text-gray-600 text-sm">
          No updates yet.
        </div>
      </div>

      <!-- Queries -->
      <div class="border p-6 rounded-lg">
        <h2 class="font-semibold mb-4">Queries</h2>

        <input
          id="queryInput"
          placeholder="Raise a query..."
          class="w-full border p-2 mb-4 rounded"
        />

        <button
          onclick="submitQuery()"
          class="bg-black text-white px-4 py-2 rounded"
        >
          Submit
        </button>

        <p id="queryStatus" class="text-sm text-gray-600 mt-3"></p>
      </div>

    </main>

  </div>

  <!-- SCRIPT -->
  <script>
    const API_BASE = "https://api.liwox.net";

    async function uploadFile() {
      const file = document.getElementById("fileInput").files[0];
      const description = document.getElementById("description").value;

      if (!file) {
        alert("Please select a file");
        return;
      }

      const formData = new FormData();
      formData.append("file", file);
      formData.append("description", description);

      document.getElementById("uploadStatus").textContent = "Uploading...";

      try {
        await fetch(`${API_BASE}/api/upload`, {
          method: "POST",
          body: formData,
          credentials: "include"
        });

        document.getElementById("uploadStatus").textContent = "Upload successful";

      } catch (err) {
        document.getElementById("uploadStatus").textContent = "Upload failed";
      }
    }

    async function submitQuery() {
      const query = document.getElementById("queryInput").value;

      if (!query) return;

      document.getElementById("queryStatus").textContent = "Submitting...";

      try {
        await fetch(`${API_BASE}/api/query`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({ query }),
          credentials: "include"
        });

        document.getElementById("queryStatus").textContent = "Query submitted";

      } catch (err) {
        document.getElementById("queryStatus").textContent = "Failed to submit";
      }
    }
  </script>

</Layout>
